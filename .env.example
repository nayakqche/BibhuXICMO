# ---------- Core ----------
NODE_ENV=development
# On Vercel, NEXT_PUBLIC_APP_URL / APP_URL / AUTH_URL fall back from VERCEL_URL when unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ---------- Database ----------
DATABASE_URL=postgresql://xicmo:xicmo@localhost:5432/xicmo?schema=public
REDIS_URL=redis://localhost:6379

# ---------- Auth (NextAuth / Auth.js v5) ----------
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000

# OAuth providers (required for “Continue with Google” / GitHub on login & register)
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# Authorized redirect URI: {APP_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- LLM providers ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
PERPLEXITY_API_KEY=
GROQ_API_KEY=

# ---------- Stripe ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MAX_MONTHLY=

# ---------- Social / channel APIs ----------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=xicmo/0.1 by your-username

X_CLIENT_ID=
X_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Facebook Login → used to connect Instagram Business / Creator accounts.
# Create the app at https://developers.facebook.com → add "Instagram"
# and "Facebook Login" products. Authorized redirect URI:
#   {APP_URL or NEXT_PUBLIC_APP_URL}/api/integrations/instagram/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---------- Google (Search Console + GA4 share these) ----------
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=

# Optional: PageSpeed Insights API (Lighthouse scores on /agent/cmo).
# Without a key it still works for low traffic; with a key you get higher quotas.
PAGESPEED_API_KEY=

# ---------- Extra LLM providers (any subset) ----------
# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=
# OpenRouter — single key for many providers — https://openrouter.ai
OPENROUTER_API_KEY=

# ---------- Vercel Cron ----------
# Set to a long random string. Vercel Cron sends this automatically as
# `Authorization: Bearer ${CRON_SECRET}` once configured in Project Settings.
CRON_SECRET=

# ---------- Email (Resend) ----------
RESEND_API_KEY=
EMAIL_FROM="Xicmo <hello@xicmo.com>"

# ---------- Storage ----------
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=xicmo-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---------- Apify (Ahrefs scraper + other actors) ----------
# Get a token at https://console.apify.com/settings/integrations
APIFY_TOKEN=
# Optional: dedicated Apify token for the X (Twitter) agent. If set, the X
# agent uses this instead of APIFY_TOKEN — useful when Ahrefs and X scraping
# should bill against separate Apify accounts. Falls back to APIFY_TOKEN.
APIFY_X_TOKEN=
# Default actor for Ahrefs-style site data. Override to swap providers.
APIFY_AHREFS_ACTOR_ID=radeance~ahrefs-scraper
# Default actor for X / Twitter tweet search (used by the X agent's reply scan).
# Swap to any compatible search-by-keyword actor (e.g. `kaitoeasyapi/twitter-x-data-tweet-scraper-pay-per-result-cheapest`).
APIFY_X_ACTOR_ID=apidojo~tweet-scraper

# Optional: dedicated Apify token for the Instagram agent. Falls back to APIFY_TOKEN.
APIFY_IG_TOKEN=
# Instagram scraper actors (swappable).
APIFY_IG_ACTOR_ID=apify~instagram-scraper
APIFY_IG_HASHTAG_ACTOR_ID=apify~instagram-hashtag-scraper
# Instagram DM automation actor. Uses session cookies — ToS-risky, opt-in.
APIFY_IG_DM_ACTOR_ID=quickads~instagram-dm-automation

# ---------- Observability ----------
SENTRY_DSN=
